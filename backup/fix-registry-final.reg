Windows Registry Editor Version 5.00

[HKEY_CURRENT_USER\Software\Classes\Directory\Background\shell\Reasonix\command]
@="wt.exe pwsh -NoExit -File \"D:\\Reasonix\\scripts\\reasonix-guard.ps1\" -TargetDir \"%V\""

