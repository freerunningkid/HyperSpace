@="wt.exe pwsh -NoExit -File \"D:\\Reasonix\\scripts\\reasonix-guard.ps1\" -TargetDir \"%1\""

[HKEY_CURRENT_USER\Software\Classes\Drive\shell\Reasonix\command]
@="wt.exe pwsh -NoExit -File \"D:\\Reasonix\\scripts\\reasonix-guard.ps1\" -TargetDir \"%1\""
