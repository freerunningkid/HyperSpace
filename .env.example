# HyperSpace 环境变量示例
# 复制为 .env 后填入真实值；不要提交 .env

# === DeepSeek Web (¥0, 主力) ===
# 无需 API Key，首次使用会自动打开浏览器让你登录 chat.deepseek.com

# === 免费兜底 Provider ===

# 智谱 GLM (免费, 必填)
ZHIPU_API_KEY=your_zhipu_api_key_here

# GitHub Models - GPT-4o (免费, OCR 能力强)
GITHUB_API_KEY=your_github_pat_here

# Agnes AI (免费, 多模态)
AGNES_API_KEY=your_agnes_api_key_here

# === 可选 ===
# Qwen / 通义千问
QWEN_API_KEY=your_qwen_api_key_here

# SiliconFlow
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
