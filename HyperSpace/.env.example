# HyperSpace 环境变量示例 —— 复制为 .env 并填入真实 key
# key 仅从 .env 读取, 不写入 .mcp.json, .env 已 gitignore

# === 免费档 (智谱 GLM-4-Flash 文本 + GLM-4V-Flash 识图, 必填, MVP 唯一硬性依赖) ===
# 获取: https://bigmodel.cn/ 控制台 → API Keys
ZHIPU_API_KEY=

# === 廉价档 (失败回退/复杂任务, 可选) ===
# DeepSeek 官方 API, ~$0.27/M, 获取: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Kimi/Moonshot, 长上下文, 获取: https://platform.moonshot.cn/
MOONSHOT_API_KEY=

# === 高精度档 (可选, 后期接 OpenRouter 上的 Claude/GPT) ===
# OPENROUTER_API_KEY=
