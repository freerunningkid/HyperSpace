# Reasonix 安装文件 — 办公室重装即可
dist/
node.exe
reasonix-desktop.exe
uninstall.exe

# 数据文件
data/

# Python
__pycache__/
*.pyc
scripts/.venv/

# Claude 运行垃圾（不同步）
backups/
debug/
downloads/
file-history/
ide/
paste-cache/
plugins/
session-env/
shell-snapshots/
tasks/
telemetry/
channels/

# Reasonix 内部临时文件（除 skills 外）
.reasonix/*
!.reasonix/skills/
.screenshot_monitor.lock
截图/

# 会话日志（每台机器独立，不同步）
config/reasonix/sessions/

# 系统垃圾
Thumbs.db
Desktop.ini

# Node 依赖
node_modules/

# Token 文件（含 API Key，严禁提交）
*token*.json
.env
